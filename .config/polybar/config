[colors]
background = ${xrdb:background}
;background = #BF000000
foreground = ${xrdb:foreground}
primary = ${xrdb:background}
secondary = ${xrdb:color3}
accent = ${xrdb:accent}
col6 = ${xrdb:color6}
alert = ${xrdb:color1}
disabled = ${xrdb:color8}

[bar/main]
width = 100%

dpi = ${xrdb:Xft.dpi}

background = ${colors.background}
foreground = ${colors.foreground}

border-size = 0
;border-right-size = 19
;height = 24
height = 30
;radius = 3
;height = 30
line-size = 3

;border-color = #00000000
border-color = ${colors.disabled}

padding-left = 0
;padding-right = 3
padding-right = 1

;separator = "‚Ēā"
separator-foreground = ${colors.disabled}

;font-0 = "SauceCodePro Nerd Font Mono:style=Bold:size=9;3"
font-0 = "ComicShannsMono Nerd Font Mono:size=12;4"

modules-left = dwm title
;modules-center = title
modules-right = pulseaudio memory temperature eth wlan battery date

module-margin = 1

cursor-click = pointer
cursor-scroll = ns-resize

enable-ipc = true

;tray-position = right

; wm-restack = generic
; wm-restack = bspwm
; wm-restack = i3

; override-redirect = true

[module/dwm]
type = internal/dwm
format = <label-tags><label-layout>
; Path to dwm socket (default: /tmp/dwm.sock)
; socket-path = /tmp/dwm.sock

; Left-click to view tag, right-click to toggle tag view
enable-tags-click = true
; Scroll to cycle between available tags
enable-tags-scroll = false
; If true and enable-tags-scroll = true, scrolling will view all tags regardless if occupied
tags-scroll-empty = false
; If true and enable-tags-scroll = true, scrolling will cycle through tags backwards
tags-scroll-reverse = false
; If true and enable-tags-scroll = true, wrap active tag when scrolling
tags-scroll-wrap = false
; Left-click to set secondary layout, right-click to switch to previous layout
enable-layout-click = true
; Scroll to cycle between available layouts
enable-layout-scroll = false
; Wrap when scrolling and reaching beginning/end of layouts
layout-scroll-wrap = false
; Reverse scroll direction
layout-scroll-reverse = false

; If enable-layout-click = true, clicking the layout symbol will switch to this layout
secondary-layout-symbol = ><>

; Separator in between shown tags
; label-separator = |

; Title of currently focused window
; Available tokens:
;   %title%
;label-title = %title%
;label-title-padding = 0
;label-title-foreground = ${colors.foreground}
;label-title-maxlen = 90

; Defaults to 'Desktop'
;label-title-default = ""
;label-title-default = "dwm"

; Symbol of current layout
; Available tokens:
;   %symbol%
label-layout = %symbol%
label-layout-padding-left = 1
label-layout-padding-right = 0
label-layout-foreground = ${colors.secondary}

; Text to show when currently focused window is floating
;label-floating = *

; States: focused, unfocused, visible, urgent, empty
; Available tokens:
;   %name%

; focused = Selected tag on focused monitor
label-focused = %name%
label-focused-background = ${colors.accent}
label-focused-foreground = ${colors.primary}
;label-focused-underline = ${colors.accent}
label-focused-padding = 1

; unfocused = Unselected tag on unselected monitor
label-unfocused = %name%
label-unfocused-padding = 1

; visible = Unselected tag, but occupied tag on any monitor
label-visible = %name%

;label-visible-foreground = ${colors.accent}
;label-visible-background = ${colors.secondary}

label-visible-padding = 1

; urgent = Unselected tag with window that has urgency hint set
label-urgent = %name%
label-urgent-background = ${colors.alert}
label-urgent-foreground = ${colors.background}
label-urgent-padding = 1

; empty = Unselected and unoccupied tag
; This can be set to an empty string to hide empty tags
label-empty = ""
label-empty-padding = 1

[module/title]
type = internal/xwindow
label = %title%
label-maxlen = 93
label-empty = dwm

[module/desktop]
type = custom/script
tail = true
exec = DESKTOP=""; cat /tmp/desktop_mode.tmp 2>/dev/null; [ $? = 0 ] && DESKTOP="ÔĄą"; echo $DESKTOP
label = "%output%"
interval = 0.1
label-foreground = ${colors.secondary}

[module/mic]
type = custom/script
tail = true
exec =  MIC=$(pactl get-source-mute @DEFAULT_SOURCE@ | awk  '{print $2}'); [ $MIC = "yes" ] && MIC="" || MIC="ÔĄį"; echo $MIC
label = "%output%"
;interval = 0.1
label-foreground = ${colors.alert}

[module/pulseaudio]
type = internal/pulseaudio

ramp-volume-0 = ÔÄ¶
ramp-volume-1 = ÔÄß
ramp-volume-2 = ÔÄ®
ramp-volume-foreground = ${colors.secondary}

format-volume = <ramp-volume> <label-volume>

label-volume = %percentage%%

label-muted = ůįĖĀ %percentage%%
label-muted-foreground = ${colors.disabled}

[module/memory]
type = internal/memory
interval = 2
format-prefix = "Ôčõ "
format-prefix-foreground = ${colors.secondary}
label = %gb_used%

[module/temperature]
type = internal/temperature
thermal-zone = 3
warn-temperature = 85

format = <ramp> <label>
format-warn = <ramp> <label-warn>
format-warn-background = ${colors.alert}
format-warn-foreground = ${colors.primary}

label = %temperature-c%
label-warn = %temperature-c%
label-warn-foreground = ${colors.primary}
label-warn-background = ${colors.alert}

ramp-0 = Ôčč
ramp-1 = Ôčä
ramp-2 = ÔčČ
ramp-3 = ÔčČ
ramp-4 = Ôčą
ramp-5 = Ôčá
ramp-foreground = ${colors.secondary}
ramp-5-foreground = ${colors.primary}

[module/date]
type = internal/date
interval = 1

date-alt = %a, %b %d, %Y %I:%M%P %Z
date = %I:%M%P

label = %date%
format-prefix = "ÔÄó "
format-prefix-foreground = ${colors.secondary}

;label-foreground = ${colors.secondary}

[module/battery]
type = internal/battery

battery = BAT1
adapter = AC

;-- Most batteries never hit 100%
full-at = 99
low-at = 20

format-charging-prefix = "ůįāĄ "  

ramp-capacity-0 = ůįĀļ
ramp-capacity-1 = ůįĀľ
ramp-capacity-1-foreground = ${colors.secondary}
ramp-capacity-2 = ůįĀĺ
ramp-capacity-2-foreground = ${colors.secondary}
ramp-capacity-3 = ůįāÄ
ramp-capacity-3-foreground = ${colors.secondary}
ramp-capacity-4 = ůįāā
ramp-capacity-4-foreground = ${colors.secondary}
ramp-capacity-5 = ůįĀĻ

format-charging = <label-charging>
format-charging-foreground = ${colors.col6}

format-discharging = <ramp-capacity> <label-discharging>

format-full = <ramp-capacity> <label-full>
format-full-foreground = ${colors.col6}

format-low = <ramp-capacity> <label-low>
format-low-foreground = ${colors.primary}
format-low-background = ${colors.alert}

label-charging = %percentage%%
label-discharging = %percentage%%
label-low = %percentage%%

[module/wlan]
type = internal/network
interface = wlp166s0

format-connected = <label-connected>
format-connected-prefix = "ůįĖ© "
format-connected-prefix-foreground = ${colors.secondary}
label-connected =ÔĀĘ%upspeed% ÔĀ£%downspeed%

label-disconnected = "" 

[module/eth]
type = internal/network
interface = enp0s13f0u1
label-connected = eth
format-connected = <label-connected>
format-connected-foreground = ${colors.secondary}

;[module/vpn]
;type = custom/script
;tail = true
;exec =  MIC=$(echo hello); echo $
;label = "%output%"
;;interval = 0.1
;format-prefix = "world"
;label-foreground = ${colors.alert}

[settings]
screenchange-reload = true
pseudo-transparency = false
